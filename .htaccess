# Block environment/secrets files from HTTP access.
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Block all dotfiles: .env, .gitignore, .git, and similar.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block common project metadata and database dumps.
<FilesMatch "^(composer\.(json|lock)|env\.example|.*\.sql)$">
    Require all denied
</FilesMatch>

# Custom error pages
ErrorDocument 403 /Test/403.php
ErrorDocument 404 /Test/404.php
