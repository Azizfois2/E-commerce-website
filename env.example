# Copy to ".env" in this folder and fill in values. Never commit .env.

# App
APP_URL=http://localhost/Test/
DEV_MODE=true

# Database
DB_HOST=localhost
DB_NAME=maroc_pc
DB_USER=root
DB_PASS=

# Mail (from address for PHP mail() / templates)
MAIL_FROM=noreply@example.com

# SMTP (PHPMailer) — Gmail needs an app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=ssl
SMTP_FROM=
SMTP_FROM_NAME=Maroc PC

# Evolution API (used for WhatsApp 2FA codes)
EVOLUTION_API_URL=https://marocpc.instatunnel.my
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=Maroc PC

# Textbee SMS API (optional - used for SMS 2FA codes)
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PayPal (optional — when both are set, PayPal orders are verified server-side)
# PAYPAL_ENV=sandbox
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# Cloudflare Turnstile CAPTCHA (optional — protects forms from spam/bot submissions)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
